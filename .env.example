# Copy to .env and fill in. Never commit .env.

# --- API ---
# Public URL the app is reachable at (used in invitation/admin links in emails)
APP_BASE_URL=https://inviter.nu
# Secret slug that unlocks /admin/<slug>/metrics. Empty disables the endpoint.
APP_DASHBOARD_SLUG=

# --- SMTP ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true
MAIL_FROM=noreply@inviter.nu
MAIL_FROM_NAME=Inviter

# --- Caddy / web ---
# E.g. ":80" for plain HTTP, or "inviter.nu" to let Caddy provision TLS.
SITE_ADDRESS=:80

# --- Grafana ---
# Initial admin password for the Grafana UI (http://localhost:3000).
GRAFANA_ADMIN_PASSWORD=admin
